rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid is string && data.uid.size() <= 256
        && data.email is string && data.email.size() <= 256;
    }

    // Match rules for users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }
  }
}
